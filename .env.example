# Calgary MediSpa AI — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ─────────────────────────────────────────────
# CLINIC INFORMATION
# ─────────────────────────────────────────────
CLINIC_NAME="Calgary MediSpa"
CLINIC_CITY="Calgary"
CLINIC_PROVINCE="AB"
CLINIC_PHYSICIAN="Dr. [Last Name]"

# ─────────────────────────────────────────────
# GOOGLE WORKSPACE (optional — for future integration)
# ─────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_FILE=config/service_account.json
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEETS_ID=
GOOGLE_CALENDAR_ID=

# ─────────────────────────────────────────────
# OPENAI (optional — for AI-enhanced outputs)
# ─────────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────────
# PAYROLL SETTINGS
# ─────────────────────────────────────────────
PAYROLL_MAX_WEEKLY_HOURS=44
PAYROLL_OVERTIME_THRESHOLD=44
PAYROLL_VACATION_PAY_RATE=0.04

# ─────────────────────────────────────────────
# OUTPUT SETTINGS
# ─────────────────────────────────────────────
OUTPUT_DIR=outputs
LOG_DIR=logs
LOG_LEVEL=INFO
