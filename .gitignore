# Calgary MediSpa AI - .gitignore

# ─────────────────────────────────────────────
# SECURITY - Never commit these files
# ─────────────────────────────────────────────
.env
config/service_account.json
config/credentials.json
config/*.json
!config/settings.example.json
*.pem
*.key

# ─────────────────────────────────────────────
# PATIENT DATA - Never commit patient data
# ─────────────────────────────────────────────
outputs/SOAP_*
outputs/Payroll_*
*.csv
*.xlsx
*.xls

# Keep output and log directories but not their contents
outputs/*
!outputs/.gitkeep
logs/*
!logs/.gitkeep

# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.venv/
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ─────────────────────────────────────────────
# Node.js
# ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ─────────────────────────────────────────────
# IDE and OS
# ─────────────────────────────────────────────
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
.idea/
*.iml

# ─────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
*.cover
.tox/

# ─────────────────────────────────────────────
# Jupyter
# ─────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb
